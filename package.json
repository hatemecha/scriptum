{
  "name": "scriptum",
  "version": "0.1.0",
  "description": "Minimal screenplay writing application built with Next.js and TypeScript.",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-dev.mjs",
    "dev:turbo": "node scripts/run-next-dev.mjs --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "validate:screenplay": "tsx scripts/validate-screenplay-foundation.ts",
    "validate:data-architecture": "tsx scripts/validate-data-architecture.ts",
    "validate:security-base": "tsx scripts/validate-security-base.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@lexical/clipboard": "^0.42.0",
    "@lexical/history": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "lexical": "^0.42.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
