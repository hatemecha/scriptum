## Public app shell
NEXT_PUBLIC_APP_NAME=Scriptum
NEXT_PUBLIC_APP_URL=http://localhost:3000

## Supabase authentication
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alternativa (nombre que muestra el dashboard en proyectos nuevos):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Registro sin verificar correo (proyecto alojado en Supabase):
# Dashboard → Authentication → Providers → Email → desactivar «Confirm email».
# Alternativa con CLI: variable SUPABASE_ACCESS_TOKEN y
#   npx supabase link --project-ref <ref>
#   npx supabase config push
# (este repo ya tiene supabase/config.toml con auth.email.enable_confirmations = false para local y como plantilla).

## Future Stripe integration
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
